   "cell_type": "code",
   "source": [
    "# raw DTA output\n",
    "file2 = \"/mnt/D/data/DTA_outputs/2024-08-28/user.kghorban.Sh_2211_Wtaunu_H_maxHTpTV2_BFilter.e8351.MC16d.v1.2024-08-28_histograms.root/user.kghorban.40997756._000001.histograms.root\"\n",
    "prefix = \"T_s1thv_\"\n",
    "df_sys_up = ROOT.RDataFrame(prefix + check_sys_up, file2).Filter(\"passReco==1\")\n",
    "df_sys_down = ROOT.RDataFrame(prefix + check_sys_down, file2).Filter(\"passReco==1\")\n",
    "df_nom = ROOT.RDataFrame(nominal, file2).Filter(\"passReco==1\")\n",
    "\n",
    "hist_sys_up = df_sys_up.Histo1D((\"\", \"\", 20, 200000, 1000000), \"TauPt\").GetValue()\n",
    "hist_sys_down = df_sys_down.Histo1D((\"\", \"\", 20, 200000, 1000000), \"TauPt\").GetValue()\n",
    "hist_nom = df_nom.Histo1D((\"\", \"\", 20, 200000, 1000000), \"TauPt\").GetValue()\n",
    "\n",
    "print(ROOT_utils.get_th1_bin_values(hist_sys_down))\n",
    "print(ROOT_utils.get_th1_bin_values(hist_nom))\n",
    "print(ROOT_utils.get_th1_bin_values(hist_sys_up))"
   ],
   "id": "64495eaf447f6faf",
   "outputs": [
    {
     "name": "stdout",
