   "cell_type": "code",
   "source": [
    "# from framework output dataframe snapshots\n",
    "df_sys_up = ROOT.RDataFrame(f\"{check_sys_up}/data_{check_sel}\", filepath).Filter(\"passReco==1\")\n",
    "df_sys_down = ROOT.RDataFrame(f\"{check_sys_down}/data_{check_sel}\", filepath).Filter(\"passReco==1\")\n",
    "df_nom = ROOT.RDataFrame(f\"{nominal}/data_{check_sel}\", filepath).Filter(\"passReco==1\")\n",
    "\n",
    "hist_sys_up = df_sys_up.Histo1D((\"\", \"\", 20, 200, 1000), \"TauPt\").GetValue()\n",
    "hist_sys_down = df_sys_down.Histo1D((\"\", \"\", 20, 200, 1000), \"TauPt\").GetValue()\n",
    "hist_nom = df_nom.Histo1D((\"\", \"\", 20, 200, 1000), \"TauPt\").GetValue()\n",
    "\n",
    "print(\"sys_down: \", ROOT_utils.get_th1_bin_values(hist_sys_down))\n",
    "print(\"nominal: \", ROOT_utils.get_th1_bin_values(hist_nom))\n",
    "print(\"sys_up: \", ROOT_utils.get_th1_bin_values(hist_sys_up))"
   ],
   "id": "4ec6b35ba7882052",
