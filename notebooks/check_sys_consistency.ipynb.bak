   "source": [
    "import numpy as np\n",
    "import ROOT\n",
    "from numba.parfors.parfor import mean_parallel_impl\n",
    "from utils import ROOT_utils\n",
    "\n",
    "ROOT_utils.load_ROOT_settings()\n",
    "\n",
    "filepath = \"/home/keanu/Uni_Stuff_Queen_Mary/Python_Projects/myFramework/outputs/analysis_test/root/wtaunu.root\"\n",
    "check_sys_up = \"TAUS_TRUEHADTAU_SME_TES_DETECTOR_Endcap_LowPt__1up\"\n",
    "check_sys_down = \"TAUS_TRUEHADTAU_SME_TES_DETECTOR_Endcap_LowPt__1down\"\n",
    "nominal = \"T_s1thv_NOMINAL\"\n",
    "check_sel = \"SR_passID\"\n",
    "check_vars = [\"TauPt\", \"MTW\"]"
   ],
   "outputs": [],
   "execution_count": 77
  },
  {
   "metadata": {
    "ExecuteTime": {
     "end_time": "2024-10-09T17:14:00.778401Z",
     "start_time": "2024-10-09T17:14:00.672329Z"
    }
   },
   "cell_type": "code",
   "source": [
    "# from framework output histograms\n",
    "tfile =  ROOT.TFile(filepath, \"read\")\n",
    "hists_sys_up = [tfile[check_sys_up][check_sel][v] for v in check_vars]\n",
    "hists_sys_down = [tfile[check_sys_down][check_sel][v] for v in check_vars]\n",
    "hists_nom = [tfile[nominal][check_sel][v] for v in check_vars]\n",
    "\n",
    "print(\"sys_down: \", ROOT_utils.get_th1_bin_values(hists_sys_down[0]))\n",
    "print(\"nominal: \", ROOT_utils.get_th1_bin_values(hists_nom[0]))\n",
    "print(\"sys_up: \", ROOT_utils.get_th1_bin_values(hists_sys_up[0]))"
   ],
   "id": "2ee2603f53c0b71f",
